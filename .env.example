# JOECLaude Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control!

# Anthropic Claude API
ANTHROPIC_API_KEY=your-api-key-here

# Application Settings
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# Analytics Settings
ANALYTICS_OUTPUT_DIR=./data/processed
ANALYTICS_EXPORT_FORMAT=json

# Server Settings (if running web dashboard)
HOST=0.0.0.0
PORT=8000